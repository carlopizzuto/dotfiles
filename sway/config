# version 1

# ======================================
# ========== MOD KEYBIND ===============
# ======================================

set $mod Mod4

# ======================================
# ========== START XWAYLAND ============
# ======================================

# Enable XWayland
xwayland enable


# ======================================
# ========== UI CUSTOMIZATION ==========
# ======================================
 
# Font for window titles. Will also be used by the bar unless a different font
# is used in the bar {} block below.
font pango:Iosevka Nerd Font 14

# Inner gaps for all windows: space between two adjacent windows (or split containers). 
gaps inner 10

# Outer gaps for all windows: space along the screen edges.
gaps outer -5

default_border pixel 5
default_floating_border pixel 5

seat * xcursor_theme Adwaita 32

output DP-3 mode 3840x2160 scale 1.5 position 1234 0 bg ~/.config/WPPRs/wallpaper_main.png fill
output DP-2 mode 3840x2160 transform 270 scale 1.75 position 0 -470 bg ~/.config/WPPRs/wallpaper_portrait.png fill


# ======================================
# ========== STARTUP EXECs =============
# ======================================

# DP-2 re-enable moved to ~/.zprofile (runs before Sway starts, so EDID is available)

# Export Wayland env vars to systemd (needed for portals, file dialogs, etc.)
exec dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP=sway GTK_THEME

# Start XDG autostart .desktop files using dex.
exec --no-startup-id dex --autostart --environment sway

# NetworkManager tray app (may or may not show depending on bar/tray)
exec --no-startup-id nm-applet

# Wallpapers are set via 'output ... bg' directives in the UI CUSTOMIZATION section

# Idle + lock (5 min → lock, 20 min in lock → screen off)
exec_always killall -q swayidle; sleep 0.2 && swayidle -w \
  timeout 300 '~/.local/bin/lock.sh' \
  before-sleep '~/.local/bin/lock.sh'

# Bar
exec_always killall -q waybar; sleep 1 && waybar

# Notifications
exec_always killall -q mako; sleep 0.2 && mako

# Volume OSD
exec_always ~/.config/sway/scripts/volume-osd.py

# Clipboard history
exec_always killall -q wl-paste; sleep 0.2 && wl-paste --watch cliphist store

# Ollama start; local LLM server
exec_always killall -q ollama; sleep 0.2 && ollama serve


# ======================================
# ========== RULES / SETS ==============
# ======================================

# set kitty as the default terminal
set $term kitty

# drag floating windows to their wanted position
floating_modifier $mod

for_window [app_id="thunar"] floating enable
for_window [app_id="org.pulseaudio.pavucontrol"] floating enable
for_window [app_id="blueman-manager"] floating enable
for_window [app_id="localsend"] floating enable, sticky enable, resize set 500 600, move position center
for_window [app_id="cava-visualizer"] resize set height 250 px


# ======================================
# ========== KEYBINDS ==================
# ======================================

# start a terminal
bindsym $mod+Return exec $term

# open zen broswer
bindsym $mod+w exec zen-browser

# open thunar file manager
bindsym $mod+e exec thunar

# reload the configuration file
bindsym $mod+Shift+c reload

# restart sway inplace
bindsym $mod+Shift+r restart

# color picker
bindsym $mod+z exec hyprpicker -a

# exit sway
bindsym $mod+Shift+e exec "swaynag -t warning -m 'Exit Sway?' -b 'Yes, exit' 'swaymsg exit'"

# kill focused window
bindsym $mod+Shift+q kill

# start rofi; program launcher
bindsym $mod+space exec --no-startup-id rofi -show drun

# rofi calculator (spotlight-like)
bindsym $mod+c exec --no-startup-id "rofi -show calc -modi calc -no-show-match -no-sort"

# Screenshot
bindsym $mod+s exec grim -g "$(slurp)" - | swappy -f -

# Clipboard manager
bindsym $mod+Shift+v exec cliphist list | wofi --dmenu | cliphist decode | wl-copy

# open cava audio visualizer below current window
bindsym $mod+Shift+a split v; exec $term --app-id cava-visualizer cava

# change focus
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

# alternatively, you can use the cursor keys:
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# move focused window
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

# alternatively, you can use the cursor keys:
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# split in horizontal orientation
bindsym $mod+n split h

# split in vertical orientation
bindsym $mod+b split v

# enter fullscreen mode for the focused container
bindsym $mod+f fullscreen toggle

# change container layout 
bindsym $mod+Shift+s layout stacking
bindsym $mod+Shift+w layout tabbed
bindsym $mod+Shift+x layout toggle split

# toggle tiling / floating
bindsym $mod+Shift+space floating toggle

# change focus between tiling / floating windows
bindsym $mod+t focus mode_toggle

# focus the parent container
bindsym $mod+a focus parent

# cycle through workspaces on current monitor
bindsym $mod+Tab workspace next_on_output
bindsym $mod+Shift+Tab workspace prev_on_output


# ======================================
# ========== WORKSPACES ================
# ======================================

set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"
set $ws11 "11"
set $ws12 "12"
set $ws13 "13"
set $ws14 "14"
set $ws15 "15"
set $ws16 "16"
set $ws17 "17"
set $ws18 "18"
set $ws19 "19"
set $ws20 "20"

# Assign workspaces to monitors
workspace $ws1 output DP-3
workspace $ws2 output DP-3
workspace $ws3 output DP-3
workspace $ws4 output DP-3
workspace $ws5 output DP-3
workspace $ws6 output DP-3
workspace $ws7 output DP-3
workspace $ws8 output DP-3
workspace $ws9 output DP-3
workspace $ws10 output DP-3

workspace $ws11 output DP-2
workspace $ws12 output DP-2
workspace $ws13 output DP-2
workspace $ws14 output DP-2
workspace $ws15 output DP-2
workspace $ws16 output DP-2
workspace $ws17 output DP-2
workspace $ws18 output DP-2
workspace $ws19 output DP-2
workspace $ws20 output DP-2

# switch to workspace
bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

bindsym $mod+Mod1+1 workspace number $ws11
bindsym $mod+Mod1+2 workspace number $ws12
bindsym $mod+Mod1+3 workspace number $ws13
bindsym $mod+Mod1+4 workspace number $ws14
bindsym $mod+Mod1+5 workspace number $ws15
bindsym $mod+Mod1+6 workspace number $ws16
bindsym $mod+Mod1+7 workspace number $ws17
bindsym $mod+Mod1+8 workspace number $ws18
bindsym $mod+Mod1+9 workspace number $ws19
bindsym $mod+Mod1+0 workspace number $ws20

# move focused container to workspace
bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

bindsym $mod+Shift+Mod1+1 move container to workspace number $ws11
bindsym $mod+Shift+Mod1+2 move container to workspace number $ws12
bindsym $mod+Shift+Mod1+3 move container to workspace number $ws13
bindsym $mod+Shift+Mod1+4 move container to workspace number $ws14
bindsym $mod+Shift+Mod1+5 move container to workspace number $ws15
bindsym $mod+Shift+Mod1+6 move container to workspace number $ws16
bindsym $mod+Shift+Mod1+7 move container to workspace number $ws17
bindsym $mod+Shift+Mod1+8 move container to workspace number $ws18
bindsym $mod+Shift+Mod1+9 move container to workspace number $ws19
bindsym $mod+Shift+Mod1+0 move container to workspace number $ws20


# ======================================
# ========== RESIZE MODE ===============
# ======================================

mode "resize" {
        bindsym h resize shrink width 5 px or 5 ppt
        bindsym k resize grow height 5 px or 5 ppt
        bindsym j resize shrink height 5 px or 5 ppt
        bindsym l resize grow width 5 px or 5 ppt

        bindsym Up resize grow height 5 px or 5 ppt
        bindsym Right resize grow width 5 px or 5 ppt
        bindsym Left resize shrink width 5 px or 5 ppt
        bindsym Down resize shrink height 5 px or 5 ppt

        bindsym Return mode "default"
        bindsym Escape mode "default"
        bindsym $mod+r mode "default"
}

bindsym $mod+r mode "resize"

# ======================================
# ========== AUDIO CONTROLS ============
# ======================================

bindsym XF86AudioRaiseVolume exec wpctl set-volume @DEFAULT_SINK@ .05+ --limit 1.0
bindsym XF86AudioLowerVolume exec wpctl set-volume @DEFAULT_SINK@ .05-
bindsym XF86AudioMute exec wpctl set-mute @DEFAULT_SINK@ toggle
bindsym XF86AudioPlay exec playerctl play-pause
bindsym XF86AudioNext exec playerctl next
bindsym XF86AudioPrev exec playerctl previous

# ======================================
# ========== AUTOSTART APPS ============
# ======================================

assign [class="Spotify"] 10

exec localsend --hidden
exec --no-startup-id swaymsg 'workspace 9; exec kitty btop'
exec --no-startup-id swaymsg 'workspace 1; exec zen-browser'
exec --no-startup-id swaymsg 'workspace 10; exec spotify'


